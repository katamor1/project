{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ibm-bob.local/schemas/document_generation_contract.schema.json",
  "title": "IBM-Bob document generation contract",
  "type": "object",
  "required": ["document"],
  "properties": {
    "schema_version": {"type": "string"},
    "document": {
      "type": "object",
      "required": ["document_name"],
      "properties": {
        "document_id": {"type": "string"},
        "document_name": {"type": "string", "minLength": 1},
        "document_type": {"type": "string"},
        "version": {"type": "string"},
        "created_date": {"type": "string"},
        "author": {"type": "string"},
        "status": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
