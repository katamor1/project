  },
  "processing": {
    "ts_service": [
      "TS_SERVICEがG02.4/G03.4を検出し、次ブロックを含む2ブロック構成を先読みする。",
      "始点、中間点、終点から円弧平面、中心、半径を算出し、同一直線/点一致条件を判定する。",
      "RT周期で処理しやすい補間セグメントまたはパラメトリックブロックへ変換する。",
      "RT_CONTROLは生成済みブロックを実行し、別Gコード指令で通常補間へ戻る。"
    ],
    "rt_control": [
      "幾何計算、分割点生成、同時制御軸の補間テーブル化はTS_SERVICEで実施する。",
      "RT_CONTROLは補間セグメントを固定長ブロックとして消費し、幾何再計算は行わない。"
    ],
    "state_machine": [
      "DISABLED",
      "ARMED",
      "PREPARED",
      "ACTIVE",
      "HOLD",
      "COMPLETE",
      "ALARM"
    ]
  },
  "errors": [
    "3点不正",
