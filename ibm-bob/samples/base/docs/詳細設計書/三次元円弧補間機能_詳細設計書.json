    "requirements": [
      "3点指定から三次元円弧軌跡が生成される",
      "不正幾何を実行前に検出する",
      "RT側では生成済みブロックのみを実行する"
    ],
    "codes": [
      "G02.4/G03.4: 3次元円弧補間モード",
      "第1ブロック: 中間点指定",
      "第2ブロック: 終点指定",
      "G01等: モード終了/切換"
    ]
  },
