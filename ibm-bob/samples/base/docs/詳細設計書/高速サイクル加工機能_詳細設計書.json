  "processing": {
    "ts_service": [
      "TS_SERVICEが高速サイクル開始を検出し、対象固定サイクルの対応可否を判定する。",
      "各サイクルを位置決め、送り、戻り、ドウェル等の固定長ステップへ展開する。",
      "RT_CONTROLがステップを順次実行し、各周期でインターロック、軸到達、スピンドル状態を監視する。",
      "サイクル終了後、重ね合わせ制御解除、G05 P0解除により通常モードへ戻る。"
    ],
    "rt_control": [
      "先読み、速度プロファイル、許容誤差判定、ジャーク/加速度制限計算はTS_SERVICEで行う。",
      "RT_CONTROLは先読み充足率とプロファイル世代を監視し、アンダーラン時は安全側速度または停止へ遷移する。",
      "サイクル展開、工具・補正・PLC条件の検証はTS_SERVICEで行い、RT_CONTROLは展開済みステップを実行する。",
      "工具、主軸、冷却、PLC応答のタイムアウトを状態遷移として管理する。"
    ],
    "state_machine": [
      "DISABLED",
      "ARMED",
      "PREPARED",
      "ACTIVE",
      "HOLD",
      "COMPLETE",
      "ALARM"
    ]
  },
