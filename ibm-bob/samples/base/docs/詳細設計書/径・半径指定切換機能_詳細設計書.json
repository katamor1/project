  "data_design": {
    "config": "CNC214_FEATURE_CONFIG",
    "request": "CNC214_FEATURE_REQUEST",
    "status": "CNC214_FEATURE_STATUS",
    "exec_block": "CNC214_EXEC_BLOCK",
    "exec_buffer": "CNC214_EXEC_BUFFER",
    "global": "g_cnc214Feature",
    "consistency": "valid flag + generation_begin/generation_end + single writer policy"
  },
  "processing": {
    "ts_service": [
      "TS_SERVICEがG10.9または外部信号を検出し、PGD設定と方式競合を確認する。",
      "バッファ実行中、軸移動中、サイクル中でないことを確認し、対象軸の指定方式を更新する。",
      "以降のNC座標値を内部半径基準または機械基準へ正規化し、RT実行ブロックへ格納する。",
      "表示系にはDPA/DPM設定に応じた座標値を提供し、RT_CONTROLには正規化済み値のみを渡す。"
    ],
    "rt_control": [
      "座標・単位・指令方式の正規化はTS_SERVICEで完了し、RT_CONTROLには内部標準単位の絶対目標値だけを渡す。",
      "座標変換モード中の禁止Gコード、補正、レファレンス点復帰、単位切換との競合を実行前に判定する。"
    ],
    "state_machine": [
      "DISABLED",
      "ARMED",
      "PREPARED",
      "ACTIVE",
      "HOLD",
      "COMPLETE",
      "ALARM"
    ]
  },
  "errors": [
    "移動中切換",
    "PGDと外部信号方式競合",
    "指令値小数点付き",
    "対象軸不正",
    "表示変換不整合"
  ],
  "constraints": [
    "軸移動中やバッファプログラム実行中の切換は禁止",
    "切削送り速度は半径基準で管理",
    "オフセットやワーク座標系は既存DIAx/ORC/ODI優先規則を尊重"
  ],
