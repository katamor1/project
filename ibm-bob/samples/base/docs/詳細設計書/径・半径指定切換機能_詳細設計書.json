  },
  "traceability": {
    "basic_design_id": "BD-CNC-214",
    "requirements": [
      "G10.9により対象軸の指定方式が切り替わる",
      "移動中切換はアラームになる",
      "RT側では正規化済み座標のみを使用する"
    ],
    "codes": [
      "G10.9 IP_: 指定軸の径/半径指定切換",
      "PGD: プログラム切換有効化",
      "DPA/DPM: 表示方式設定",
      "DM1〜DM8: 切換中出力信号"
    ]
  },
  "module_design": {
    "header": "include/cnc214_feature.h",
    "source": "src/cnc214_feature.c",
    "test": "tests/test_cnc214_feature.c",
    "ts_functions": [
      "Ts_CNC214_Prepare",
      "Ts_CNC214_CommitExecBuffer"
    ],
