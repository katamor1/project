  "feature": {
    "feature_id": "FX-BD-213",
    "name": "G83深穴サイクル機能",
    "summary": "深穴加工でペック量ごとに切削し、R平面まで戻って切りくずを排出しながら加工する。",
    "classification": {
      "realtime_control": true,
      "time_share_processing": true,
      "api_change": true,
      "global_variable_change": true,
      "state_machine": true,
      "sequence_control": true
    },
    "estimated_new_steps": "300-900 step"
  },
  "introduction": {
    "purpose": "G83深穴サイクル機能の基本設計を、IBM-Bob基盤上で実装可能なモジュール、データ構造、RT/TS/API処理、状態遷移、異常安全へ展開する。",
    "scope": "G83 X Y Z R Q P F K、G80、G98/G99 を対象に、NCプログラム/MDI/APIからの要求をRT制御で実行する範囲。",
    "out_of_scope": "サーボドライブ内部制御、機械メーカー固有PMC詳細、最終加工条件の決定。",
    "assumptions": [
      "Windows C基盤",
      "RT/TS分離",
      "共有メモリ固定長構造体",
      "RT内ファイルI/O禁止"
    ],
    "design_granularity_policy": "関数・構造体・処理順序まで具体化するが、ソースコード全文は記載しない。"
  },
