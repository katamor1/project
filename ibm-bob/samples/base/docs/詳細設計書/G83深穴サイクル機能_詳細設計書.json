    "ts_slice_policy": "TSは1スライスで処理量を制限し、割込再開に備えて中断可能なstep単位に分割する。"
  },
  "rt_design": {
    "steps": [
      {
        "order": 1,
        "function": "G83DeepHole_LatchRequestRt",
        "inputs": [
          "g_g83_deep_holeCommand"
        ],
        "process": "generationとrequestを確認し、固定長ローカル構造体へコピーする。",
        "outputs": [
          "local_request"
        ],
        "error_branch": "世代不一致なら前回要求を保持",
        "estimated_us": "1-3"
      },
      {
        "order": 2,
        "function": "G83DeepHole_CheckInterlockRt",
        "inputs": [
          "g_machineCtx",
          "g_ioIn",
          "local_request"
        ],
        "process": "非常停止、サーボ異常、モード条件、併用不可機能を判定する。",
        "outputs": [
          "interlock_ok"
        ],
        "error_branch": "NG時はERROR/ALARMへ遷移",
        "estimated_us": "2-5"
      },
      {
        "order": 3,
        "function": "G83DeepHole_UpdateStateRt",
        "inputs": [
          "local_request",
          "current_state"
        ],
        "process": "Qごとに送り込み、各ペック後にR平面まで完全退避して切りくず排出を行う。",
        "outputs": [
          "g_g83_deep_holeStatus"
        ],
        "error_branch": "異常時は安全側出力とログ要求",
        "estimated_us": "5-20"
      },
      {
        "order": 4,
        "function": "G83DeepHole_CommitOutputRt",
        "inputs": [
          "state",
          "command"
        ],
        "process": "g_ioOutへ軸/主軸/PLC指令を反映し、ALARM中は安全側マスクを適用する。",
        "outputs": [
          "g_ioOut"
        ],
        "error_branch": "安全側出力を優先",
        "estimated_us": "2-8"
      }
    ],
    "prohibited_operations": [
      "Windows system call",
      "file I/O",
      "dynamic memory allocation",
      "blocking wait",
      "unbounded loop"
    ],
    "fallback_policy": "TS未準備、ready不成立、パラメータ不整合時は前回有効値または安全側停止へ遷移する。"
  },
  "ts_design": {
    "steps": [
      {
        "order": 1,
        "function": "G83DeepHole_ParseBlockTs",
        "trigger": "NC先読み/MDI入力",
        "process": "G83 X Y Z R Q P F K、G80、G98/G99 を字句解析し、機能コードとアドレスを抽出する。",
        "io": "ファイルI/OはTS側のみ",
        "update_order": "解析結果はローカル領域に保持",
        "failure_policy": "構文異常をNCアラームとして登録"
      },
      {
        "order": 2,
        "function": "G83DeepHole_ValidateParamTs",
        "trigger": "解析完了",
        "process": "X/Y、Z、R、Qペック量、Pドウェル、F、K、戻り量/再切込み隙間 の範囲、単位、モード、併用不可条件を確認する。",
        "io": "設定ファイル読込み可",
        "update_order": "valid=falseのまま検証",
        "failure_policy": "不正値はRTへ渡さずアラーム"
      },
      {
        "order": 3,
        "function": "G83DeepHole_BuildPlanTs",
        "trigger": "検証OK",
        "process": "複数RT周期に分割可能な固定長実行計画へ展開する。",
        "io": "なし",
        "update_order": "command/paramを書込み、generation更新後にrequest=1",
        "failure_policy": "バッファ不足時はTS側で保留"
      },
      {
        "order": 4,
        "function": "G83DeepHole_WriteTraceTs",
        "trigger": "状態変化/異常",
        "process": "TS側でCSV/診断ログに記録する。",
        "io": "ファイルI/Oあり",
        "update_order": "g_logQueueを消費",
        "failure_policy": "ログ保存失敗はWARN、RT処理は継続"
      }
    ],
    "io_policy": "I/O and heavy calculation are TS only",
    "interruption_policy": "各ステップは中間結果をローカルに保持し、共有メモリ公開は検証完了後に一括実施する。"
  },
