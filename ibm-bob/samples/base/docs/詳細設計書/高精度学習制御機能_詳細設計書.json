  "processing": {
    "ts_service": [
      "初回加工でRT_CONTROLが固定長リングバッファへ誤差サンプルを記録する。",
      "TS_SERVICEがサンプルを回収し、異常値除去、平均化、補正上限処理を行う。",
      "生成した学習補正テーブルを世代番号付きで共有領域に登録する。",
      "次回以降RT_CONTROLが補正テーブルを周期的に適用し、効果を再評価する。"
    ],
    "rt_control": [
      "先読み、速度プロファイル、許容誤差判定、ジャーク/加速度制限計算はTS_SERVICEで行う。",
      "RT_CONTROLは先読み充足率とプロファイル世代を監視し、アンダーラン時は安全側速度または停止へ遷移する。",
      "RT_CONTROLは周期内で軽量な監視・サンプル記録のみを行い、詳細解析・保存・統計処理はTS_SERVICEで行う。",
      "安全監視はフェイルセーフ優先とし、診断ログはRT要求をTSが後段で永続化する。"
    ],
    "state_machine": [
      "DISABLED",
      "ARMED",
      "PREPARED",
      "ACTIVE",
      "HOLD",
      "COMPLETE",
      "ALARM"
    ]
  },
