  "processing": {
    "ts_service": [
      "TS_SERVICEがG08開始を受理し、対象区間の先読みを開始する。",
      "隣接ブロックの方向差、長さ、送り速度から丸め可否を判定する。",
      "許容誤差内のブレンド曲線または補間点列を生成し、RT用バッファに登録する。",
      "RT_CONTROLは登録済みブロックを周期実行し、G08 P0で通常ブロック消費へ戻る。"
    ],
    "rt_control": [
      "先読み、速度プロファイル、許容誤差判定、ジャーク/加速度制限計算はTS_SERVICEで行う。",
      "RT_CONTROLは先読み充足率とプロファイル世代を監視し、アンダーラン時は安全側速度または停止へ遷移する。"
    ],
    "state_machine": [
      "DISABLED",
      "ARMED",
      "PREPARED",
      "ACTIVE",
      "HOLD",
      "COMPLETE",
      "ALARM"
    ]
  },
  "errors": [
