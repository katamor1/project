  "processing": {
    "ts_service": [
      "TS_SERVICEがG05 P10000を単独ブロックとして受理し、補正状態とネスト条件を検証する。",
      "先読み範囲の線分長、曲率、コーナ角を評価し、送り速度と減速点を算出する。",
      "オフセット値変更がある場合、Dワードブロックからの有効化タイミングを実行ブロックへ反映する。",
      "RT_CONTROLはプロファイルに従い補間を実行し、G05 P0で通常補間へ戻る。"
    ],
    "rt_control": [
      "先読み、速度プロファイル、許容誤差判定、ジャーク/加速度制限計算はTS_SERVICEで行う。",
      "RT_CONTROLは先読み充足率とプロファイル世代を監視し、アンダーラン時は安全側速度または停止へ遷移する。"
    ],
    "state_machine": [
      "DISABLED",
      "ARMED",
      "PREPARED",
      "ACTIVE",
      "HOLD",
      "COMPLETE",
      "ALARM"
    ]
  },
  "errors": [
    "補正ネスト不正",
    "オプション未有効",
