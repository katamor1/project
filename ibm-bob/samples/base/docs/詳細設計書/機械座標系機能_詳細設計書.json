  "traceability": {
    "basic_design_id": "BD-CNC-218",
    "requirements": [
      "G53ブロックのみ機械座標系で移動する",
      "次ブロックで元のワーク座標系に戻る",
      "未原点復帰状態では実行されない"
    ],
    "codes": [
      "G53: 機械座標系での一時移動",
      "G28等: レファレンス点復帰状態との関係",
      "G50/G51/G68等: 併用禁止対象"
    ]
  },
  "module_design": {
    "header": "include/cnc218_feature.h",
    "source": "src/cnc218_feature.c",
    "test": "tests/test_cnc218_feature.c",
