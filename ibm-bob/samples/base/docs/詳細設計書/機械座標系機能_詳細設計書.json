    ]
  },
  "data_design": {
    "config": "CNC218_FEATURE_CONFIG",
    "request": "CNC218_FEATURE_REQUEST",
    "status": "CNC218_FEATURE_STATUS",
    "exec_block": "CNC218_EXEC_BLOCK",
    "exec_buffer": "CNC218_EXEC_BUFFER",
    "global": "g_cnc218Feature",
    "consistency": "valid flag + generation_begin/generation_end + single writer policy"
  },
  "processing": {
    "ts_service": [
      "TS_SERVICEがG53を検出し、アブソリュート指令であることとレファレンス点復帰済みであることを確認する。",
      "補正、スケーリング、ミラー、座標回転などの併用禁止状態をチェックする。",
      "移動先が機械リミット内であることを確認し、RT_CONTROL用の機械座標移動ブロックを生成する。",
      "RT_CONTROLは指定ブロックを実行し、完了後は元のワーク座標系状態に戻る。"
    ],
    "rt_control": [
      "座標・単位・指令方式の正規化はTS_SERVICEで完了し、RT_CONTROLには内部標準単位の絶対目標値だけを渡す。",
      "座標変換モード中の禁止Gコード、補正、レファレンス点復帰、単位切換との競合を実行前に判定する。"
    ],
    "state_machine": [
      "DISABLED",
      "ARMED",
      "PREPARED",
      "ACTIVE",
      "HOLD",
      "COMPLETE",
      "ALARM"
    ]
  },
  "errors": [
    "未原点復帰",
    "インクレメンタルG53",
    "補正/座標変換併用",
    "機械リミット超過",
    "安全領域外移動"
  ],
  "constraints": [
    "G53はモーダルではなくワンショット",
    "インクレメンタル指令不可",
    "レファレンス点復帰前は使用禁止",
    "補正・座標変換との同一ブロック併用禁止"
  ],
