    "exec_buffer": "CNC201_EXEC_BUFFER",
    "global": "g_cnc201Feature",
    "consistency": "valid flag + generation_begin/generation_end + single writer policy"
  },
  "processing": {
    "ts_service": [
      "TS_SERVICEがG68/G69を解析し、対象平面、中心点、角度、絶対/増分指定の妥当性を確認する。",
      "TS_SERVICEが固定小数点または倍精度で回転行列を生成し、NC実行ブロックへ変換済み目標座標を格納する。",
      "RT_CONTROLは変換済みの目標座標のみを使用し、周期内では三角関数計算を行わない。",
      "G69受理時にTS_SERVICEが変換状態を解除し、解除直後ブロックの絶対座標明示をチェックする。"
    ],
    "rt_control": [
      "座標・単位・指令方式の正規化はTS_SERVICEで完了し、RT_CONTROLには内部標準単位の絶対目標値だけを渡す。",
      "座標変換モード中の禁止Gコード、補正、レファレンス点復帰、単位切換との競合を実行前に判定する。"
    ],
    "state_machine": [
      "DISABLED",
      "ARMED",
      "PREPARED",
      "ACTIVE",
      "HOLD",
      "COMPLETE",
      "ALARM"
    ]
  },
  "errors": [
    "回転角未指定または範囲外",
    "回転中の禁止Gコード指令",
    "解除直後の位置不明確指令",
    "変換結果が軸リミットを超過"
  ],
  "constraints": [
    "座標回転中の座標系変更、レファレンス点復帰、平面変更は原則禁止",
    "工具径補正、スケーリング、他の座標変換との併用順序を明確化",
    "解除直後は絶対座標で現在位置を明示"
  ],
