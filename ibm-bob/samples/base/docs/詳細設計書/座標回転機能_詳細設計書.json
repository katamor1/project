  "traceability": {
    "basic_design_id": "BD-CNC-201",
    "requirements": [
      "G68/G69の開始・解除で座標変換状態が正しく遷移する",
      "RT周期内で追加計算負荷が一定上限を超えない",
      "禁止組合せ指令で安全にアラーム停止する"
    ],
    "codes": [
      "G68: 座標回転モード開始。X/Y/Z等の平面内中心座標、R角度を指定",
      "G69: 座標回転モード解除",
      "G17/G18/G19: 回転対象平面の選択"
    ]
  },
