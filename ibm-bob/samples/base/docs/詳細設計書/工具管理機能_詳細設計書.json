  "processing": {
    "ts_service": [
      "TS_SERVICEがTコードを解析し、工具管理テーブルから工具番号、補正番号、寿命状態を取得する。",
      "交換が必要な場合はPLC向け工具交換要求を生成し、応答完了まで状態を監視する。",
      "RT_CONTROLは現在工具の有効/無効、補正値、寿命警告状態を周期内インターロックに使用する。",
      "加工完了または使用時間更新時にTS_SERVICEが寿命カウンタを更新し、必要に応じてログ保存する。"
    ],
    "rt_control": [
      "サイクル展開、工具・補正・PLC条件の検証はTS_SERVICEで行い、RT_CONTROLは展開済みステップを実行する。",
      "工具、主軸、冷却、PLC応答のタイムアウトを状態遷移として管理する。"
    ],
    "state_machine": [
      "DISABLED",
      "ARMED",
      "PREPARED",
      "ACTIVE",
      "HOLD",
      "COMPLETE",
      "ALARM"
    ]
  },
