  },
  "processing": {
    "ts_service": [
      "TS_SERVICEが工具形状と干渉禁止領域を登録し、RT監視用の簡略化境界ボックスへ変換する。",
      "RT_CONTROLが各周期で対象経路の現在位置と境界領域の重なりを判定する。",
      "干渉予測時は対象経路へ段階減速または即停止要求を出し、g_machineCtx相当のアラーム状態を設定する。",
      "TS_SERVICEが詳細ログを保存し、再起動時の安全退避ルート確認を支援する。"
    ],
    "rt_control": [
      "RT_CONTROLは周期内で軽量な監視・サンプル記録のみを行い、詳細解析・保存・統計処理はTS_SERVICEで行う。",
      "安全監視はフェイルセーフ優先とし、診断ログはRT要求をTSが後段で永続化する。"
    ],
    "state_machine": [
      "DISABLED",
      "ARMED",
      "PREPARED",
      "ACTIVE",
      "HOLD",
      "COMPLETE",
      "ALARM"
    ]
  },
  "errors": [
    "干渉予測",
    "領域データ未登録",
    "工具形状不整合",
    "監視対象経路不正",
    "退避ルート未設定"
  ],
  "constraints": [
    "2経路以上のマルチパス制御機で有効",
    "工具形状・領域登録精度が安全性を左右",
    "RT計算量を抑えるため監視モデルの複雑度を制限"
  ],
