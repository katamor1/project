    "requirements": [
      "登録領域の重なりをRT周期内で検出できる",
      "干渉予測時に対象経路を安全停止できる",
      "工具形状未登録時に加工開始を禁止できる"
    ],
    "codes": [
      "専用パラメータ: 2経路/多経路チェック選択",
      "干渉禁止領域登録画面/PMC入力",
      "干渉検出動作設定: 警告/減速/停止"
    ]
  },
