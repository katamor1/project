  "processing": {
    "ts_service": [
      "TS_SERVICEがG68.2〜G68.4を単独ブロックとして解析し、指定方式に応じて特徴座標系を算出する。",
      "機械構成、回転軸制限、工具中心点制御条件を確認し、変換行列を生成する。",
      "後続ブロックを変換済み座標・姿勢へ正規化し、RT向け実行ブロックに格納する。",
      "G69で変換状態を解除し、通常ワーク座標系へ戻す。"
    ],
    "rt_control": [
      "座標・単位・指令方式の正規化はTS_SERVICEで完了し、RT_CONTROLには内部標準単位の絶対目標値だけを渡す。",
      "座標変換モード中の禁止Gコード、補正、レファレンス点復帰、単位切換との競合を実行前に判定する。"
    ],
    "state_machine": [
      "DISABLED",
      "ARMED",
      "PREPARED",
      "ACTIVE",
      "HOLD",
      "COMPLETE",
      "ALARM"
    ]
  },
  "errors": [
    "回転角範囲外",
    "姿勢解なし",
    "回転軸リミット超過",
    "併用禁止モード",
    "工具中心点制御未有効"
  ],
  "constraints": [
    "5軸制御および工具中心点制御オプションが必要",
    "傾斜平面中の他座標変換、座標系設定、スケーリングとの併用を制限",
    "RT側で行列生成・逆運動学探索を行わない"
  ],
