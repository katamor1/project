  "metadata": {
    "document_id": "BD-CNC-314",
    "feature_name": "ロールオーバ機能",
    "category": "回転軸制御",
    "version": "0.1",
    "created_date": "2026-04-29",
    "source_document": "設計_ロールオーバ機能.docx"
  },
  "purpose": "回転軸の絶対位置指令を0〜360度範囲で適切に丸め、連続回転や最短経路回転を制御してインデックステーブル等の角度位置決めを容易にする。",
  "overview": "ROTx/ROSx/ROAx/RABx/RRLx等の回転軸設定を管理し、Aタイプ回転軸に対してロールオーバ処理を行う。TS_SERVICEが設定確認し、RT_CONTROLが変換済み角度指令を実行する。",
  "interfaces": {
    "codes": [
      "ROTx/ROSx: 回転軸およびA/Bタイプ設定",
      "ROAx: ロールオーバ有効化",
      "RABx: アブソリュート指令時の回転方向選択",
      "RRLx: 相対指令丸め",
      "No.1260相当: 1回転移動量"
    ],
    "inputs": [
      "回転軸指令角度",
      "回転軸タイプ",
      "ロールオーバ設定",
      "絶対/増分指定",
      "機械ストローク制限"
    ],
    "outputs": [
      "丸め後角度指令",
      "回転方向選択結果",
      "ロールオーバ状態",
      "設定不正アラーム"
    ]
  },
  "architecture": {
    "baseline": "Windows C言語マルチスレッド機械制御基盤。RT_INPUT/RT_CONTROL/RT_OUTPUTを割込周期内で実行し、TS_SERVICEがファイルI/O、NC解析、ログ、HMI/API連携を担当する。",
    "shared_memory": [
      "g_ioIn",
      "g_ioOut",
      "g_machineCtx",
      "g_uiRequest",
      "g_logQueue",
      "g_prefetchResult"
    ],
    "public_api_compatibility": [
      "Api_RequestRunModeChange",
      "Api_GetStatusSnapshot",
      "Api_RequestLogFlush",
      "Api_GetPrefetchStatus"
    ],
    "rt_rules": [
      "Windows API呼出禁止",
      "ファイルI/O禁止",
      "動的メモリ確保禁止",
      "長時間ブロッキング禁止",
      "1割込周期内完了"
    ]
  },
  "process_flow": [
    "TS_SERVICEが対象軸の回転軸設定、A/Bタイプ、ROAx有効状態を確認する。",
    "絶対/増分指令に応じて角度丸め、近回り、符号方向、相対丸めを計算する。",
    "RT_CONTROLへ連続性を持つ角度指令を渡し、軸リミットと機械的ストッパーを監視する。",
    "設定変更時は電源再投入要否やHMI表示を更新する。"
  ],
  "constraints": [
    "Bタイプ回転軸ではロールオーバ不可。",
    "機械的ストッパーを超える回転は禁止。",
    "パラメータ変更後の再起動要否を運用に明記する。"
  ],
  "alarms": [
    "Bタイプ軸で有効化",
    "1回転移動量未設定",
    "回転方向設定競合",
    "機械ストッパー超過",
    "対象軸非回転軸"
  ],
  "acceptance_criteria": [
    "Aタイプ回転軸で360度超過指令が適切に丸められる。",
    "RAB/RRL設定に従い方向と丸めが変わる。",
    "Bタイプ軸では実行前に拒否される。"
  ],
  "build_test": {
    "vc2026": "cmd /c scripts\\build_vc2026.bat && cmd /c scripts\\test_vc2026.bat",
    "clang_windows": "cmd /c scripts\\build_clang.bat && cmd /c scripts\\test_clang.bat"
  },
