{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IBM-Bob Review Result Schema",
  "type": "object",
  "required": [
    "review"
  ],
  "properties": {
    "review": {
      "type": "object",
      "required": [
        "review_id",
        "target",
        "decision",
        "summary",
        "check_results",
        "issues"
      ],
      "properties": {
        "review_id": {
          "type": "string"
        },
        "review_type": {
          "type": "string"
        },
        "review_date": {
          "type": "string"
        },
        "target": {
          "type": "object",
          "required": [
            "document_type",
            "feature_id",
            "feature_name"
          ],
          "properties": {
            "document_type": {
              "type": "string"
            },
            "document_name": {
              "type": "string"
            },
            "feature_id": {
              "type": "string"
            },
            "feature_name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          }
        },
        "decision": {
          "type": "string",
          "enum": [
            "合格",
            "条件付き合格",
            "差戻し",
            "保留",
            "未判定"
          ]
        },
        "summary": {
          "type": "object",
          "properties": {
            "ok_count": {
              "type": "integer"
            },
            "warn_count": {
              "type": "integer"
            },
            "ng_count": {
              "type": "integer"
            },
            "na_count": {
              "type": "integer"
            },
            "unchecked_count": {
              "type": "integer"
            }
          }
        },
        "check_results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "check_id",
              "status",
              "severity",
              "evidence",
              "comment"
            ],
            "properties": {
              "check_id": {
                "type": "string"
              },
              "category": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "OK",
                  "WARN",
                  "NG",
                  "N/A",
                  "未確認"
                ]
              },
              "severity": {
                "type": "string",
                "enum": [
                  "Critical",
                  "High",
                  "Medium",
                  "Low",
                  "Info"
                ]
              },
              "evidence": {
                "type": "string"
              },
              "comment": {
                "type": "string"
              },
              "recommendation": {
                "type": "string"
              }
            }
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "issue_id",
              "severity",
              "category",
              "location",
              "description",
              "recommendation",
              "status"
            ],
            "properties": {
              "issue_id": {
                "type": "string"
              },
              "severity": {
                "type": "string"
              },
              "category": {
                "type": "string"
              },
              "location": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "evidence": {
                "type": "string"
              },
              "recommendation": {
                "type": "string"
              },
              "owner": {
                "type": "string"
              },
              "due_date": {
                "type": "string"
              },
              "status": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}