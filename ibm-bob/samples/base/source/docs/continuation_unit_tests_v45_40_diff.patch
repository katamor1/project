+    EXPECT_EQ_U32(block.interlock_mask, 0u); \
+    EXPECT_EQ_U32(block.sequence_gate_mask, 0u); \
+    EXPECT_EQ_U32(block.diagnostics_mask, 0u); \
+    EXPECT_EQ_U32(block.trace_event_code, 0u); \
+}
