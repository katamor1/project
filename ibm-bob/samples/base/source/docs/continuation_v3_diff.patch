+static int32_t BuildCannedCyclePlan(const NC_EXEC_BLOCK* pBlock)
+{
+    int32_t atR[AXIS_MAX];
+    int32_t atDepth[AXIS_MAX];
+    int32_t current[AXIS_MAX];
+    int32_t retract[AXIS_MAX];
+    int32_t rZ;
+    int32_t targetZ;
+    int32_t direction;
+    uint32_t step;
+    uint32_t i;
+    uint32_t pecks = 0U;
+
+    ResetSegmentPlan();
+    CopyAxes(atR, pBlock->axis_start);
+    CopyAxes(atDepth, pBlock->axis_target);
+    rZ = ((pBlock->feature_flags & NC_FEATURE_FLAG_PARAM_R) != 0U) ?
+         pBlock->r_value : pBlock->axis_start[2];
+    targetZ = pBlock->axis_target[2];
+
+    for (i = 0U; i < AXIS_MAX; ++i) {
+        atR[i] = pBlock->axis_target[i];
+    }
+    atR[2] = rZ;
+
+    if (AppendLinearAuto(pBlock->axis_start, atR, 1U, NC_SEG_KIND_RAPID) != 0) {
+        return -1;
+    }
+
+    if ((IsDrillingCycle(pBlock->cycle_code10) != 0U) &&
+        ((pBlock->feature_flags & NC_FEATURE_FLAG_PARAM_Q) != 0U) &&
+        (pBlock->q_value != 0)) {
+        CopyAxes(current, atR);
+        step = AbsDiff32(0, pBlock->q_value);
+        direction = (targetZ >= rZ) ? 1 : -1;
+        if (step == 0U) {
+            step = AbsDiff32(rZ, targetZ);
+        }
+        while (current[2] != targetZ) {
+            uint32_t remaining = AbsDiff32(current[2], targetZ);
+            uint32_t move = (remaining < step) ? remaining : step;
+            if (move == 0U) {
+                break;
+            }
+            CopyAxes(atDepth, current);
+            atDepth[2] = current[2] + ((direction > 0) ? (int32_t)move : -(int32_t)move);
+            if (((direction > 0) && (atDepth[2] > targetZ)) ||
+                ((direction < 0) && (atDepth[2] < targetZ))) {
+                atDepth[2] = targetZ;
+            }
+            if (AppendLinearAuto(current, atDepth, 0U, NC_SEG_KIND_LINEAR) != 0) {
+                return -1;
+            }
+            pecks++;
+            CopyAxes(current, atDepth);
+            if (current[2] != targetZ) {
+                CopyAxes(retract, current);
+                retract[2] = rZ;
+                if (AppendLinearAuto(current, retract, 1U, NC_SEG_KIND_RETRACT) != 0) {
+                    return -1;
+                }
+                if (AppendLinearAuto(retract, current, 1U, NC_SEG_KIND_RAPID) != 0) {
+                    return -1;
+                }
+                /* Logical peck depth must advance after the temporary retract. */
+            }
+        }
+    } else {
+        if (AppendLinearAuto(atR, pBlock->axis_target, 0U, NC_SEG_KIND_LINEAR) != 0) {
+            return -1;
+        }
+    }
+
+    if ((NeedsBottomDwell(pBlock->cycle_code10) != 0U) &&
+        (pBlock->p_word != 0U)) {
+        if (AppendSegment(pBlock->axis_target,
+                          pBlock->axis_target,
+                          pBlock->p_word,
+                          NC_SEG_KIND_DWELL) != 0) {
+            return -1;
+        }
+    }
+
+    CopyAxes(retract, pBlock->axis_target);
+    retract[2] = (pBlock->return_mode == 1U) ? pBlock->axis_start[2] : rZ;
+    if (AppendLinearAuto(pBlock->axis_target, retract, 1U, NC_SEG_KIND_RETRACT) != 0) {
+        return -1;
+    }
+
+    g_ncCycleStatus.peck_index = pecks;
+    return 0;
+}
