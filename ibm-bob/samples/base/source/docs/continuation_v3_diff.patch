+    return (s_segmentCount == 0U) ? 0U : s_segments[s_segmentCount - 1U].end_tick;
+}
+
+static uint32_t EstimateTicksForLinear(const int32_t* pStart,
+                                       const int32_t* pEnd,
+                                       uint8_t rapid)
+{
+    uint32_t i;
+    uint64_t maxDelta = 0U;
+    uint32_t ticks;
+
+    for (i = 0U; i < AXIS_MAX; ++i) {
+        uint32_t d = AbsDiff32(pStart[i], pEnd[i]);
+        if ((uint64_t)d > maxDelta) {
+            maxDelta = (uint64_t)d;
+        }
+    }
+
+    if (rapid != 0U) {
+        ticks = (uint32_t)((maxDelta / (uint64_t)(NC_POSITION_SCALE * 20)) + 1U);
+    } else {
+        ticks = (uint32_t)((maxDelta / (uint64_t)(NC_POSITION_SCALE * 5)) + 1U);
+    }
+    if (ticks < NC_INTERP_MIN_TICKS) {
+        ticks = NC_INTERP_MIN_TICKS;
+    }
+    if (ticks > NC_INTERP_MAX_TICKS) {
+        ticks = NC_INTERP_MAX_TICKS;
+    }
+    return ticks;
+}
+
+static int32_t AppendSegment(const int32_t* pStart,
+                             const int32_t* pEnd,
+                             uint32_t ticks,
+                             uint8_t kind)
+{
+    NC_ACTIVE_SEGMENT* pSeg;
+
+    if (s_segmentCount >= NC_CANNED_MAX_SEGMENTS) {
+        return -1;
+    }
+    if (ticks == 0U) {
+        ticks = NC_INTERP_MIN_TICKS;
+    }
+    pSeg = &s_segments[s_segmentCount];
+    CopyAxes(pSeg->start, pStart);
+    CopyAxes(pSeg->end, pEnd);
+    pSeg->kind = kind;
+    pSeg->end_tick = LastSegmentEndTick() + ticks;
+    s_segmentCount++;
+    return 0;
+}
+
+static int32_t AppendLinearAuto(const int32_t* pStart,
+                                const int32_t* pEnd,
+                                uint8_t rapid,
+                                uint8_t kind)
+{
+    return AppendSegment(pStart,
+                         pEnd,
+                         EstimateTicksForLinear(pStart, pEnd, rapid),
+                         kind);
+}
