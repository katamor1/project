+static uint8_t IsDrillingCycle(uint16_t cycleCode10)
+{
+    return (uint8_t)((cycleCode10 == NC_G_CODE_WHOLE(73)) ||
+                     (cycleCode10 == NC_G_CODE_WHOLE(81)) ||
+                     (cycleCode10 == NC_G_CODE_WHOLE(82)) ||
+                     (cycleCode10 == NC_G_CODE_WHOLE(83)) ||
+                     (cycleCode10 == NC_G_CODE_WHOLE(85)) ||
+                     (cycleCode10 == NC_G_CODE_WHOLE(86)) ||
+                     (cycleCode10 == NC_G_CODE_WHOLE(88)) ||
+                     (cycleCode10 == NC_G_CODE_WHOLE(89)));
+}
+
+static uint8_t NeedsBottomDwell(uint16_t cycleCode10)
+{
+    return (uint8_t)((cycleCode10 == NC_G_CODE_WHOLE(82)) ||
+                     (cycleCode10 == NC_G_CODE_WHOLE(89)));
+}
