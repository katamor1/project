diff -ruN '--exclude=build' '--exclude=build_gcc' '--exclude=*.o' '--exclude=sample_nc_program.nc' extracted/source/src/nc_design_features.c source/src/nc_design_features.c
--- extracted/source/src/nc_design_features.c	1970-01-01 00:00:00.000000000 +0000
+++ source/src/nc_design_features.c	2026-05-02 01:00:36.593822736 +0000
@@ -0,0 +1,24 @@
+/* ibm-bob/samples/base/source/src/nc_design_features.c */
+#include <string.h>
+#include "nc_design_features.h"
+#include "nc_codes.h"
+#include "nc_program.h"
+#define G(whole)       NC_G_CODE_WHOLE(whole)
+#define GD(whole, dec) NC_G_CODE10((whole), (dec))
+static uint16_t s_autoCornerOverride = NC_DESIGN_AUTO_CORNER_OVERRIDE_PERCENT;
+static uint8_t IsMotion(NC_MOTION_TYPE m){return (uint8_t)((m==NC_MOTION_RAPID)||(m==NC_MOTION_LINEAR)||(m==NC_MOTION_ARC_CW)||(m==NC_MOTION_ARC_CCW)||(m==NC_MOTION_CANNED_CYCLE)||(m==NC_MOTION_THREAD)||(m==NC_MOTION_SKIP)||(m==NC_MOTION_REFERENCE_RETURN)||(m==NC_MOTION_ADVANCED_INTERP));}
+static void CopyAxes(int32_t* d,const int32_t* s){uint32_t a;for(a=0U;a<AXIS_MAX;++a){d[a]=s[a];}}
+static int32_t Abs32(int32_t v){if(v==(int32_t)0x80000000UL){return 0x7fffffff;}return(v<0)?-v:v;}
+static uint32_t BitCount(uint32_t m){uint32_t c=0U;while(m!=0U){c+=(m&1U);m>>=1U;}return c;}
+static uint8_t IsGrindingCycle(uint16_t c){return (uint8_t)(((c>=(uint16_t)GD(70,7))&&(c<=(uint16_t)GD(76,7)))||((c>=(uint16_t)G(77))&&(c<=(uint16_t)G(79))));}
+static uint8_t IsHelicalB(const NC_EXEC_BLOCK* b){uint8_t arc=(uint8_t)((b->motion_type==NC_MOTION_ARC_CW)||(b->motion_type==NC_MOTION_ARC_CCW)||(b->g_code10==(uint16_t)G(2))||(b->g_code10==(uint16_t)G(3)));return (uint8_t)((arc!=0U)&&((b->axis_mask&((1UL<<2U)|(1UL<<3U)))!=0U));}
+static uint8_t IsThreeDInterference(const NC_EXEC_BLOCK* b){return (uint8_t)((BitCount(b->axis_mask)>=3U)||((b->feature_flags&(NC_FEATURE_FLAG_TILTED_PLANE|NC_FEATURE_FLAG_TOOL_AXIS_DIR))!=0U));}
+static uint8_t IsFollowupRollover(const NC_EXEC_BLOCK* b){uint32_t a;if(b->motion_type!=NC_MOTION_REFERENCE_RETURN){return 0U;}for(a=0U;a<AXIS_MAX;++a){if((b->axis_mask&(1UL<<a))==0U){continue;}if(Abs32(b->axis_target[a])>g_ncReferenceStatus.rollover_limit[a]){return 1U;}}return 0U;}
+static void StoreTargets(const NC_EXEC_BLOCK* b){uint32_t a;g_ncDesignFeatureStatus.last_g_code10=b->g_code10;g_ncDesignFeatureStatus.last_line_no=b->line_no;g_ncDesignFeatureStatus.last_axis_mask=b->axis_mask;CopyAxes((int32_t*)g_ncDesignFeatureStatus.last_output_target,b->axis_target);for(a=0U;a<AXIS_MAX;++a){g_ncDesignFeatureStatus.last_following_error[a]=b->axis_target[a]-b->axis_start[a];g_ncDesignFeatureStatus.last_clearance[a]=NC_INTERFERENCE_AXIS_LIMIT-Abs32(b->axis_target[a]);}}
+static void MarkTs(uint32_t m,NC_EXEC_BLOCK* b){g_ncDesignFeatureStatus.active_mode_mask|=m;g_ncDesignFeatureStatus.ts_adjusted_blocks++;StoreTargets(b);g_ncDesignFeatureStatus.generation++;}
+static void ApplyFeedSlowdown(NC_EXEC_BLOCK* b,uint16_t p){if((b->feed>0)&&(p>0U)&&(p<100U)){b->feed=(int32_t)(((int64_t)b->feed*(int64_t)p)/100LL);if(b->feed<=0){b->feed=1;}g_ncDesignFeatureStatus.slowdown_applied_blocks++;g_ncDesignFeatureStatus.active_override_percent=p;}}
+static void ApplyCylindricalAxisHint(NC_EXEC_BLOCK* b){if((b->axis_mask&(1UL<<3U))!=0U){int32_t v=b->axis_target[3]/360;b->axis_target[1]+=v;b->axis_mask|=(1UL<<1U);}}
+void NcDesignFeatures_Reset(void){(void)memset((void*)&g_ncDesignFeatureStatus,0,sizeof(g_ncDesignFeatureStatus));s_autoCornerOverride=NC_DESIGN_AUTO_CORNER_OVERRIDE_PERCENT;g_ncDesignFeatureStatus.active_override_percent=s_autoCornerOverride;}
+int32_t NcDesignFeatures_ApplyBlockTs(NC_EXEC_BLOCK* b,NC_ERROR_CODE* e){uint32_t m=0U;if((b==0)||(e==0)){return -1;}CopyAxes((int32_t*)g_ncDesignFeatureStatus.last_input_target,b->axis_target);if(b->g_code10==(uint16_t)GD(6,2)){g_ncDesignFeatureStatus.nurbs_blocks++;b->feature_flags|=NC_FEATURE_FLAG_ADVANCED_INTERP;b->motion_type=NC_MOTION_ADVANCED_INTERP;if(b->interp_ticks<NC_DESIGN_ADVANCED_MIN_TICKS){b->interp_ticks=NC_DESIGN_ADVANCED_MIN_TICKS;}m|=NC_DESIGN_MODE_NURBS;}if((b->g_code10==(uint16_t)GD(2,3))||(b->g_code10==(uint16_t)GD(3,3))){g_ncDesignFeatureStatus.exponential_blocks++;b->feature_flags|=NC_FEATURE_FLAG_ADVANCED_INTERP;b->motion_type=NC_MOTION_ADVANCED_INTERP;ApplyFeedSlowdown(b,90U);m|=NC_DESIGN_MODE_EXPONENTIAL;}if((b->g_code10==(uint16_t)GD(7,1))||(b->g_code10==(uint16_t)GD(12,1))){g_ncDesignFeatureStatus.cylindrical_active=1U;g_ncDesignFeatureStatus.cylindrical_blocks++;ApplyCylindricalAxisHint(b);m|=NC_DESIGN_MODE_CYLINDRICAL;}if(b->g_code10==(uint16_t)GD(13,1)){g_ncDesignFeatureStatus.cylindrical_active=0U;g_ncDesignFeatureStatus.cylindrical_blocks++;m|=NC_DESIGN_MODE_CYLINDRICAL;}if(b->g_code10==(uint16_t)G(16)){g_ncDesignFeatureStatus.polar_active=1U;g_ncDesignFeatureStatus.polar_blocks++;m|=NC_DESIGN_MODE_POLAR;}else if(b->g_code10==(uint16_t)G(15)){g_ncDesignFeatureStatus.polar_active=0U;g_ncDesignFeatureStatus.polar_blocks++;m|=NC_DESIGN_MODE_POLAR;}else if((g_ncDesignFeatureStatus.polar_active!=0U)&&(IsMotion(b->motion_type)!=0U)){g_ncDesignFeatureStatus.polar_blocks++;ApplyFeedSlowdown(b,95U);m|=NC_DESIGN_MODE_POLAR;}if(IsHelicalB(b)!=0U){g_ncDesignFeatureStatus.helical_b_blocks++;b->feature_flags|=NC_FEATURE_FLAG_ADVANCED_INTERP;if(b->interp_ticks<NC_DESIGN_ADVANCED_MIN_TICKS){b->interp_ticks=NC_DESIGN_ADVANCED_MIN_TICKS;}m|=NC_DESIGN_MODE_HELICAL_B;}if(b->g_code10==(uint16_t)G(62)){g_ncDesignFeatureStatus.auto_corner_active=1U;g_ncDesignFeatureStatus.auto_corner_override_blocks++;m|=NC_DESIGN_MODE_AUTO_CORNER;}else if(b->g_code10==(uint16_t)G(64)){g_ncDesignFeatureStatus.auto_corner_active=0U;m|=NC_DESIGN_MODE_AUTO_CORNER;}else if((g_ncDesignFeatureStatus.auto_corner_active!=0U)&&(IsMotion(b->motion_type)!=0U)){g_ncDesignFeatureStatus.auto_corner_override_blocks++;ApplyFeedSlowdown(b,s_autoCornerOverride);m|=NC_DESIGN_MODE_AUTO_CORNER;}if(IsGrindingCycle(b->cycle_code10)!=0U){g_ncDesignFeatureStatus.grinding_cycle_blocks++;b->feature_flags|=NC_FEATURE_FLAG_CANNED_CYCLE;ApplyFeedSlowdown(b,70U);m|=NC_DESIGN_MODE_GRINDING;}if((b->motion_type==NC_MOTION_SKIP)&&((b->axis_mask&(1UL<<3U))!=0U)){g_ncDesignFeatureStatus.egb_skip_armed=1U;g_ncDesignFeatureStatus.egb_skip_blocks++;m|=NC_DESIGN_MODE_EGB_SKIP;}if(IsThreeDInterference(b)!=0U){g_ncDesignFeatureStatus.three_d_interference_blocks++;ApplyFeedSlowdown(b,85U);m|=NC_DESIGN_MODE_3D_INTERFERENCE;}if(IsFollowupRollover(b)!=0U){g_ncDesignFeatureStatus.followup_rollover_blocks++;b->feature_flags|=NC_FEATURE_FLAG_REFERENCE_RETURN;m|=NC_DESIGN_MODE_FOLLOWUP_ROLLOVER;}if(m!=0U){MarkTs(m,b);}return 0;}
+void NcDesignFeatures_OnBlockRt(const NC_EXEC_BLOCK* b){uint32_t m=0U;if(b==0){return;}if(b->g_code10==(uint16_t)GD(6,2)){m|=NC_DESIGN_MODE_NURBS;}if((b->g_code10==(uint16_t)GD(2,3))||(b->g_code10==(uint16_t)GD(3,3))){m|=NC_DESIGN_MODE_EXPONENTIAL;}if((b->g_code10==(uint16_t)GD(7,1))||(b->g_code10==(uint16_t)GD(12,1))||(b->g_code10==(uint16_t)GD(13,1))){m|=NC_DESIGN_MODE_CYLINDRICAL;}if((b->g_code10==(uint16_t)G(15))||(b->g_code10==(uint16_t)G(16))||(g_ncDesignFeatureStatus.polar_active!=0U)){m|=NC_DESIGN_MODE_POLAR;}if(IsHelicalB(b)!=0U){m|=NC_DESIGN_MODE_HELICAL_B;}if((b->g_code10==(uint16_t)G(62))||(g_ncDesignFeatureStatus.auto_corner_active!=0U)){m|=NC_DESIGN_MODE_AUTO_CORNER;}if(IsGrindingCycle(b->cycle_code10)!=0U){m|=NC_DESIGN_MODE_GRINDING;}if((b->motion_type==NC_MOTION_SKIP)&&((b->axis_mask&(1UL<<3U))!=0U)){m|=NC_DESIGN_MODE_EGB_SKIP;}if(IsThreeDInterference(b)!=0U){m|=NC_DESIGN_MODE_3D_INTERFERENCE;}if(IsFollowupRollover(b)!=0U){m|=NC_DESIGN_MODE_FOLLOWUP_ROLLOVER;}if(m!=0U){g_ncDesignFeatureStatus.rt_executed_blocks++;StoreTargets(b);g_ncDesignFeatureStatus.generation++;NcEvent_Push(NC_EVENT_CODE_DESIGN_FEATURE_APPLIED,(int32_t)m,(int32_t)b->g_code10,b->line_no);}}
+int32_t NcDesignFeatures_SetAutoCornerOverride(uint8_t en,uint16_t p){if(p>NC_FEED_OVERRIDE_MAX_PERCENT){g_ncDesignFeatureStatus.generation++;return -1;}s_autoCornerOverride=p;g_ncDesignFeatureStatus.auto_corner_active=(en!=0U)?1U:0U;g_ncDesignFeatureStatus.active_override_percent=p;g_ncDesignFeatureStatus.generation++;NcEvent_Push(NC_EVENT_CODE_DESIGN_FEATURE_APPLIED,(int32_t)NC_DESIGN_MODE_AUTO_CORNER,(int32_t)p,0U);return 0;}
