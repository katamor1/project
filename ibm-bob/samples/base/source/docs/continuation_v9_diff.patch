+static int32_t ClampSymmetric(int32_t value, int32_t limit, uint8_t* pLimited)
+{
+    int32_t normalized = NormalizeLimit(limit, NC_MOTION_FILTER_AXIS_LIMIT_MAX);
+    if (value > normalized) {
+        if (pLimited != 0) {
+            *pLimited = 1U;
+        }
+        return normalized;
+    }
+    if (value < -normalized) {
+        if (pLimited != 0) {
+            *pLimited = 1U;
+        }
+        return -normalized;
+    }
+    return value;
+}
