+static int32_t NormalizeLimit(int32_t value, int32_t fallback)
+{
+    if (value < 0) {
+        value = -value;
+    }
+    if (value == 0) {
+        value = fallback;
+    }
+    if (value > NC_MOTION_FILTER_AXIS_LIMIT_MAX) {
+        value = NC_MOTION_FILTER_AXIS_LIMIT_MAX;
+    }
+    return value;
+}
