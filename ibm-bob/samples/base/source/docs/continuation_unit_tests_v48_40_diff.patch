+static void test_21_apply_ts_null_block_is_rejected_no_crash(void) {
+    v48_reset();
+    ASSERT_EQ_INT(V48_ERR_NULL, v48_apply_ts(NULL));
+    ASSERT_EQ_INT(0, g_v48_status.applied_ts_count);
+}
