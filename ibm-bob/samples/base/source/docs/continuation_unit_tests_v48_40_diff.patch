+    v48_reset();
+    V48_NC_BLOCK b = v48_default_block();
+    ASSERT_EQ_INT(V48_OK, v48_apply_ts(&b));
+    ASSERT_EQ_INT(0, b.x);
+    ASSERT_EQ_INT(100, b.feed_override_percent);
