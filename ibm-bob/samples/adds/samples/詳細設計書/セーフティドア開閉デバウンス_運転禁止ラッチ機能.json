  },
  "rt_design": {
    "steps": [
      {
        "no": 1,
        "text": "ドア入力bitを取得する"
      },
      {
        "no": 2,
        "text": "前回値と異なる場合はdebounce_countを初期化する"
      },
      {
        "no": 3,
        "text": "連続一致が設定回数以上で安定状態を更新する"
      },
      {
        "no": 4,
        "text": "開安定を検出した場合はoperation_inhibit_latchをONにする"
      },
      {
        "no": 5,
        "text": "解除要求はSTOPPEDかつ閉安定の場合のみ処理する"
      }
    ],
    "prohibited_operations": [
      "Windowsシステムコール",
      "ファイルI/O",
      "動的メモリ確保",
      "長時間ループ",
      "ブロッキング待ち"
    ],
    "fallback_policy": "ready不成立、キュー満杯、条件未成立時は既存安全側動作を優先し、必要に応じてログキューへ投入する。"
  },
  "ts_design": {
    "steps": [
      {
        "no": 1,
        "text": "ドア状態変化ログをCSVへ出力する"
      },
      {
        "no": 2,
        "text": "UI向けに現在状態、ラッチ、解除不可理由を整形する"
      }
    ],
    "io_policy": "CSV/ログ/ファイル保存はTS_SERVICEでのみ実行する。",
    "interruption_policy": "RT割込により中断されても中間状態を公開しないよう、ローカルバッファ作成後にbusy/result/stateを固定順で更新する。"
  },
