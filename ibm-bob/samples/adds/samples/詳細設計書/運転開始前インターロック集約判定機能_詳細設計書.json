  "design_policy": {
    "purpose": "自動運転開始要求の直前に、既存の複数インターロック条件を1か所で集約判定し、開始可否、禁止理由、最初に検出されたNG理由、判定スナップショットを共有メモリへ公開する。",
    "scope": [
      "リアルタイムスレッドでのインターロック条件サンプリングと判定",
      "タイムシェアスレッドでの判定結果ログ出力とUI向けメッセージ生成",
      "外部UI/APIからの現在判定結果参照",
      "既存運転開始処理への開始許可ゲート追加"
    ],
    "out_of_scope": [
      "個別センサ異常判定ロジックそのものの変更",
      "安全PLC側の安全回路設計変更",
      "UI画面レイアウトの詳細設計",
      "既存アラームコード体系の全面変更"
    ],
    "realtime_constraints": [
      "RT側でファイルI/O、メモリ確保、文字列整形、Windows API呼び出しを行わない。",
      "RT側追加処理は最大監視項目数16点時に10usec以下を目標とし、詳細実装後に実測する。",
      "複数フィールド更新は世代番号を用いた順序制御で読取側の不整合を抑止する。"
    ]
  },
