  "target_system": {
    "system_name": "IBM-Bob 基盤システム",
    "platform": "Windows / C言語",
    "thread_model": "ハードウェア割込で周期実行するリアルタイムスレッドと、空き時間にタイムスライス駆動するタイムシェアスレッドで構成する。",
    "compiler_profiles": [
