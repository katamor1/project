  "thread_design": {
    "rt_thread": {
      "entry": "StartInterlock_RtStep(uint32_t rtTick)",
      "period": "既存RT周期に従う",
      "responsibilities": [
        "開始判定要求受付",
        "入力スナップショット取得",
        "入力安定確認",
        "禁止理由集約",
        "開始許可/禁止結果公開"
      ],
      "forbidden_operations": [
        "ファイルI/O",
        "malloc/free",
        "printf/sprintf等の重い文字列整形",
        "Sleep/Wait系API",
        "Windowsシステムコール"
      ]
    },
    "ts_thread": {
      "entry": "StartInterlock_TsStep(void)",
      "responsibilities": [
        "ts_log_request監視",
        "判定結果ログ出力",
        "UI向けメッセージID生成",
        "ログ済み世代更新"
      ],
      "notes": "TS側は判定結果を変更しない。RTが確定した結果の副次処理のみ実行する。"
    },
    "api_thread": {
      "entry": "Api_GetStartInterlockStatus(START_INTERLOCK_STATUS* pStatus)",
      "responsibilities": [
        "外部アプリへの安定スナップショット返却"
      ],
      "notes": "APIは参照専用とし、開始判定要求の書込みは既存開始処理に集約する。"
    }
  },
  "state_machine": {
    "initial_state": "START_ILK_IDLE",
    "transitions": [
      {
        "from": "IDLE",
        "event": "request==1",
        "to": "REQUESTED",
        "action": "結果フラグとカウンタ初期化"
      },
      {
        "from": "REQUESTED",
        "event": "次RT周期",
        "to": "SAMPLING",
        "action": "入力スナップショット取得開始"
      },
      {
        "from": "SAMPLING",
        "event": "同一スナップショットがSTART_ILK_STABLE_TICK継続",
        "to": "EVALUATING",
        "action": "安定入力を判定対象として確定"
      },
      {
        "from": "SAMPLING",
        "event": "スナップショット変化",
        "to": "SAMPLING",
        "action": "stable_count=0"
      },
      {
        "from": "EVALUATING",
        "event": "reason_mask==0",
        "to": "ALLOWED",
        "action": "allowed=1, blocked=0, ts_log_request=1"
      },
      {
        "from": "EVALUATING",
        "event": "reason_mask!=0",
        "to": "BLOCKED",
        "action": "allowed=0, blocked=1, primary_reason設定, ts_log_request=1"
      },
      {
        "from": "SAMPLING/EVALUATING",
        "event": "timeout_count>=START_ILK_TIMEOUT_TICK",
        "to": "TIMEOUT",
        "action": "blocked=1, primary_reason=判定タイムアウト"
      },
      {
        "from": "ALLOWED/BLOCKED/TIMEOUT",
        "event": "request==0かつ結果参照完了",
        "to": "IDLE",
        "action": "状態のみIDLEへ戻す。直近結果は保持する。"
      }
    ]
  },
