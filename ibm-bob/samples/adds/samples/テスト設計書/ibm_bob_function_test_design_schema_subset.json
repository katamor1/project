{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IBM-Bob Function Test Design Schema v1.0 (subset)",
  "type": "object",
  "required": [
    "schema_version",
    "document",
    "source_documents",
    "test_policy",
    "test_environment",
    "traceability",
    "test_cases"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "document": {
      "type": "object",
      "required": [
        "document_id",
        "document_name",
        "document_type",
        "version",
        "feature_id",
        "feature_name"
      ]
    },
    "source_documents": {
      "type": "array"
    },
    "test_policy": {
      "type": "object"
    },
    "test_environment": {
      "type": "object"
    },
    "traceability": {
      "type": "array"
    },
    "test_cases": {
      "type": "array",
      "minItems": 1
    },
    "coverage_matrix": {
      "type": "array"
    },
    "review_checklist": {
      "type": "array"
    }
  }
}