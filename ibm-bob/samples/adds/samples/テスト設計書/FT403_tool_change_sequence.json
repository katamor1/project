  "test_strategy": {
    "normal_policy": "代表的な正常シーケンスを確認する。",
    "abnormal_policy": "異常入力、タイムアウト、キュー満杯、停止要求を注入する。",
    "boundary_policy": "閾値直前/直後、最大件数、保持tick境界を確認する。",
    "rt_policy": "RTではファイルI/O、Windowsシステムコール、動的メモリ確保を行わない。",
    "regression_policy": "既存の運転モード、ログ、API状態取得、RT周期監視を併走する。"
  },
