      "steps": "RT周期を進める; 各状態を記録",
      "expected_results": "許可された順序のみで遷移する",
      "priority": "High"
    },
    {
      "id": "FTC-403-004",
      "category": "異常安全",
      "title": "異常入力時に安全側へ遷移する",
      "preconditions": "異常条件を注入",
      "steps": "タイムアウト+1周期実行; 出力確認",
      "expected_results": "ERROR/ABORT/安全出力が成立",
      "priority": "High"
    },
    {
      "id": "FTC-403-005",
      "category": "API/証跡",
      "title": "API応答と証跡ログを確認",
      "preconditions": "ログ有効、APIスタブ有効",
      "steps": "API実行; ログ/CSV/JSONを確認",
      "expected_results": "応答コード、共有メモリ、証跡が一致",
      "priority": "Medium"
    },
    {
      "id": "FTC-403-006",
