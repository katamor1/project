{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/ibm-bob-basic-design-v2.schema.json",
  "title": "IBM-Bob Basic Design Structured File",
  "type": "object",
  "required": [
    "schema_version",
    "document_control",
    "feature",
    "system_context",
    "functional_requirements",
    "thread_allocation",
    "impact_analysis",
    "test_acceptance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "ibm-bob-basic-design/2.0"
    },
    "review_status": {
      "type": "string",
      "enum": [
        "draft",
        "pre_reviewed",
        "human_reviewed",
        "approved"
      ]
    },
    "document_control": {
      "type": "object",
      "required": [
        "document_id",
        "title",
        "target_version",
        "created_at",
        "author"
      ],
      "properties": {
        "document_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "target_version": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "reviewer": {
          "type": "string"
        },
        "approver": {
          "type": "string"
        },
        "revision_history": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": true
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "design_policy": {
            "type": "string"
          },
          "acceptance": {
            "type": "string"
          }
        }
      }
    },
    "feature": {
      "type": "object",
      "required": [
        "feature_id",
        "name",
        "summary"
      ],
      "properties": {
        "feature_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "actor": {
          "type": "string"
        },
        "priority": {
          "type": "string"
        },
        "related_requirement_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "classification": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "system_context": {
      "type": "object",
      "required": [
        "system_name",
        "environment",
        "threads",
        "shared_memory",
        "constraints"
      ],
      "additionalProperties": true
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "purpose_background": {
      "type": "object",
      "additionalProperties": true
    },
    "functional_requirements": {
      "type": "object",
      "additionalProperties": true
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "state_machine": {
      "type": "object",
      "additionalProperties": true
    },
    "sequence_design": {
      "type": "object",
      "additionalProperties": true
    },
    "data_design": {
      "type": "object",
      "additionalProperties": true
    },
    "interfaces": {
      "type": "object",
      "additionalProperties": true
    },
    "thread_allocation": {
      "type": "object",
      "additionalProperties": true
    },
    "non_functional": {
      "type": "object",
      "additionalProperties": true
    },
    "error_safety_design": {
      "type": "object",
      "additionalProperties": true
    },
    "logging_diagnostics": {
      "type": "object",
      "additionalProperties": true
    },
    "security": {
      "type": "object",
      "additionalProperties": true
    },
    "impact_analysis": {
      "type": "object",
      "required": [
        "items"
      ],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "target_type",
              "target",
              "impact",
              "change_required"
            ]
          }
        }
      },
      "additionalProperties": true
    },
    "test_acceptance": {
      "type": "object",
      "additionalProperties": true
    },
    "implementation_plan": {
      "type": "object",
      "additionalProperties": true
    },
    "appendix": {
      "type": "object",
      "additionalProperties": true
    },
    "pre_review": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}