{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/ibm-bob-function-test-design-v1.schema.json",
  "title": "IBM-Bob Function Test Design Structured File",
  "type": "object",
  "required": [
    "schema_version",
    "document_control",
    "source_documents",
    "feature",
    "introduction",
    "traceability",
    "feature_under_test",
    "test_strategy",
    "test_environment",
    "entry_exit_criteria",
    "test_viewpoints",
    "coverage_matrix",
    "test_data",
    "test_cases",
    "shared_memory_tests",
    "rt_performance_tests",
    "fault_safety_tests",
    "evidence_logging",
    "regression_tests",
    "execution_procedure",
    "judgement_review",
    "build_test_commands",
    "open_issues"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "ibm-bob-function-test-design/1.0"
    },
    "review_status": {
      "type": "string",
      "enum": [
        "draft",
        "pre_reviewed",
        "human_reviewed",
        "approved"
      ]
    },
    "document_control": {
      "type": "object",
      "required": [
        "document_id",
        "title",
        "target_system",
        "target_version",
        "created_at",
        "author"
      ],
      "properties": {
        "document_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "target_system": {
          "type": "string"
        },
        "target_version": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "reviewer": {
          "type": "string"
        },
        "approver": {
          "type": "string"
        },
        "revision_history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "source_documents": {
      "type": "object",
      "required": [
        "basic_design_id",
        "detail_design_id"
      ],
      "properties": {
        "basic_design_id": {
          "type": "string"
        },
        "detail_design_id": {
          "type": "string"
        },
        "requirement_doc_id": {
          "type": "string"
        },
        "basic_design_path": {
          "type": "string"
        },
        "detail_design_path": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "feature": {
      "type": "object",
      "required": [
        "feature_id",
        "name",
        "summary"
      ],
      "properties": {
        "feature_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "classification": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "automation_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "section_map": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "introduction": {
      "type": "object",
      "additionalProperties": true
    },
    "traceability": {
      "type": "object",
      "properties": {
        "basic_design": {
          "type": "object",
          "additionalProperties": true
        },
        "detail_design": {
          "type": "object",
          "additionalProperties": true
        },
        "requirement_doc": {
          "type": "object",
          "additionalProperties": true
        },
        "existing_test_doc": {
          "type": "object",
          "additionalProperties": true
        },
        "matrix": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "feature_under_test": {
      "type": "object",
      "additionalProperties": true
    },
    "test_strategy": {
      "type": "object",
      "additionalProperties": true
    },
    "test_environment": {
      "type": "object",
      "additionalProperties": true
    },
    "entry_exit_criteria": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "type",
              "condition",
              "verification"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "開始",
                  "終了",
                  "中断",
                  "前提",
                  "後処理"
                ]
              },
              "condition": {
                "type": "string"
              },
              "verification": {
                "type": "string"
              },
              "action_if_not_met": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "test_viewpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "description",
          "source_sections"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "source_sections": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "test_case_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "severity": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "coverage_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "target_type",
          "target_id",
          "verification",
          "test_case_ids",
          "coverage_status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "target_type": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "verification": {
            "type": "string"
          },
          "test_case_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "coverage_status": {
            "type": "string",
            "enum": [
              "covered",
              "partial",
              "missing",
              "N/A"
            ]
          },
          "gap_action": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "test_data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "item",
          "value_pattern",
          "setup_method"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "item": {
            "type": "string"
          },
          "value_pattern": {
            "type": "string"
          },
          "setup_method": {
            "type": "string"
          },
          "test_case_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_meaning": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "test_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "title",
          "preconditions",
          "steps",
          "expected_results"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "steps_summary": {
            "type": "string"
          },
          "expected_results_summary": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "priority": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "step_no",
                "action",
                "expected"
              ],
              "properties": {
                "step_no": {
                  "type": "string"
                },
                "action": {
                  "type": "string"
                },
                "observation_target": {
                  "type": "string"
                },
                "expected": {
                  "type": "string"
                },
                "triage": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          },
          "expected_results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "target_type": {
                  "type": "string"
                },
                "target": {
                  "type": "string"
                },
                "expected_value": {
                  "type": "string"
                },
                "tolerance": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "state_sequence_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "shared_memory_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "api_integration_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "rt_performance_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "fault_safety_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "evidence_logging": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "regression_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "execution_procedure": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "judgement_review": {
      "type": "object",
      "properties": {
        "criteria": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "defect_policy": {
          "type": "string"
        },
        "conditional_pass_policy": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "build_test_commands": {
      "type": "object",
      "properties": {
        "vc2026": {
          "type": "object",
          "additionalProperties": true
        },
        "clang_windows": {
          "type": "object",
          "additionalProperties": true
        },
        "workspace_profiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "functional_test_command": {
          "type": "string"
        },
        "functional_test_log": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "open_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "ai_review": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "object",
          "additionalProperties": true
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "overall_judgement": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "appendix": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}