{
  "fetch": {
    "command": "uvx",
    "args": [
      "mcp-server-fetch"
    ]
  },
  "filesystem": {
    "command": "npx",
    "args": [
      "-y",
      "@modelcontextprotocol/server-filesystem",
      "."
    ]
  },
  "tree_sitter": {
    "command": "uvx",
    "args": [
      "mcp-server-tree-sitter"
    ]
  },
  "semgrep": {
    "command": "uvx",
    "args": [
      "semgrep-mcp"
    ]
  },
  "github": {
    "command": "npx",
    "args": [
      "-y",
      "@modelcontextprotocol/server-github"
    ]
  }
}
