# .gitignore
# Ignores generated workspace settings, rule bundles, and local KB artifacts.
# This exists so generated files do not become source-controlled project logic.
# RELEVANT FILES: ibm-bob/mode-pack/README.md, .agents/skills/legacy-basic-design-agent/SKILL.md, .agents/skills/legacy-basic-design-agent/scripts/build_kb.py
.bob/custom_modes.yaml
.bob/rules-*/
.bob/ibm-bob/
artifacts/ibm-bob/
ibm-bob/mode-pack/scripts/__pycache__/
*.legacy-kb.sqlite
*.legacy-kb.sqlite-*
*.legacy-kb.log.jsonl
.agents/skills/legacy-basic-design-agent/.work/
.agents/skills/legacy-basic-design-agent/scripts/__pycache__/
/ibm-bob/samples/base/docs/requirements
