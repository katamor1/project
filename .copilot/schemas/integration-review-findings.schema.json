// .copilot/schemas/integration-review-findings.schema.json
// Defines the integration review findings schema for pass, revise, and block decisions on draft bundles.
// This exists so integration review can route back to the right draft author without free-text ambiguity.
// RELEVANT FILES: .copilot/prompts/sdlc/ibmbob-sdlc-integration-reviewer.md, .copilot/routing/sdlc/ibmbob-integration-flow.yaml, docs/sdlc/templates/review-summary.md
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "integration-review-findings.schema.json",
  "title": "Integration Review Findings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_refs",
    "review_decision",
    "findings",
    "revise_to",
    "human_checkpoint",
    "next_agent"
  ],
  "properties": {
    "artifact_refs": { "type": "array", "items": { "type": "string" } },
    "review_decision": { "type": "string", "enum": ["pass", "revise", "block"] },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "severity", "title", "detail"],
        "properties": {
          "category": {
            "type": "string",
            "enum": ["frontend_contract", "backend_contract", "sqlite_migration", "test_coverage", "bundle_boundary", "repo_mapping", "blocking"]
          },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "title": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    },
    "revise_to": {
      "type": "string",
      "enum": [
        "ibmbob-sdlc-integration-bundle-planner",
        "ibmbob-sdlc-frontend-draft-author",
        "ibmbob-sdlc-backend-draft-author",
        "ibmbob-sdlc-sqlite-draft-author",
        "ibmbob-sdlc-test-draft-author",
        "ibmbob-sdlc-request-orchestrator",
        "none"
      ]
    },
    "human_checkpoint": { "type": "boolean" },
    "next_agent": {
      "type": "string",
      "enum": [
        "ibmbob-sdlc-integration-bundle-planner",
        "ibmbob-sdlc-frontend-draft-author",
        "ibmbob-sdlc-backend-draft-author",
        "ibmbob-sdlc-sqlite-draft-author",
        "ibmbob-sdlc-test-draft-author",
        "ibmbob-sdlc-approval-pack-author",
        "ibmbob-sdlc-request-orchestrator"
      ]
    }
  }
}

