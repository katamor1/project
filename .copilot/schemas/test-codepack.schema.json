// .copilot/schemas/test-codepack.schema.json
// Defines the test codepack schema used to describe near-code unit, integration, and regression packs.
// This exists so test intent can be reviewed as concrete targets before any test code is generated.
// RELEVANT FILES: .copilot/prompts/P13_test_codepack_author.md, docs/sdlc/templates/test-codepack.md, .copilot/schemas/execution-review-findings.schema.json
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "test-codepack.schema.json",
  "title": "Test Codepack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_manifest",
    "slice_id",
    "target_files",
    "unit_cases",
    "integration_cases",
    "regression_cases",
    "fixtures",
    "next_agent"
  ],
  "properties": {
    "artifact_manifest": { "$ref": "./artifact-manifest.schema.json" },
    "slice_id": { "type": "string" },
    "target_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "purpose", "skeleton_outline"],
        "properties": {
          "path": { "type": "string" },
          "purpose": { "type": "string" },
          "skeleton_outline": { "type": "string" }
        }
      }
    },
    "unit_cases": { "type": "array", "items": { "$ref": "#/$defs/testCase" } },
    "integration_cases": { "type": "array", "items": { "$ref": "#/$defs/testCase" } },
    "regression_cases": { "type": "array", "items": { "$ref": "#/$defs/testCase" } },
    "fixtures": { "type": "array", "items": { "type": "string" } },
    "next_agent": { "type": "string", "const": "P14_execution_reviewer" }
  },
  "$defs": {
    "testCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "title", "focus"],
      "properties": {
        "case_id": { "type": "string" },
        "title": { "type": "string" },
        "focus": { "type": "string" }
      }
    }
  }
}
