// .copilot/schemas/relation-edge.schema.json
// Defines the relation edge schema used to connect screens, APIs, tables, errors, and batches.
// This exists so retrieval can expand through trusted graph edges instead of reading unrelated chunks.
// RELEVANT FILES: .copilot/prompts/runtime/ibmbob-relation-extractor.md, .copilot/routing/runtime/ibmbob-runtime-ingest-flow.yaml, docs/external-runtime/legacy-kb/data-pipeline.md
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "relation-edge.schema.json",
  "title": "Relation Edge",
  "type": "object",
  "additionalProperties": false,
  "required": ["edge_id", "source_entity", "target_entity", "relation_type", "source_refs", "confidence"],
  "properties": {
    "edge_id": { "type": "string" },
    "source_entity": { "type": "string" },
    "target_entity": { "type": "string" },
    "relation_type": { "type": "string" },
    "source_refs": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}

