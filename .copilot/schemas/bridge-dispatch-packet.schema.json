// .copilot/schemas/bridge-dispatch-packet.schema.json
// Defines the bridge dispatch packet schema used to hand Copilot requests into the external runtime.
// This exists so runtime target, task type, and callback expectations are fixed before K0 starts.
// RELEVANT FILES: .copilot/prompts/C3_dispatch_packet_author.md, .copilot/prompts/K0_runtime_orchestrator.md, docs/copilot-studio/custom-engine-bridge/dispatch-contract.md
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bridge-dispatch-packet.schema.json",
  "title": "Bridge Dispatch Packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["bridge_request_ref", "identity_context_ref", "runtime_target", "runtime_task_type", "callback_contract", "next_agent"],
  "properties": {
    "bridge_request_ref": { "type": "string" },
    "identity_context_ref": { "type": "string" },
    "runtime_target": { "type": "string" },
    "runtime_task_type": { "type": "string" },
    "callback_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["response_agent", "expected_result_type", "context_ref", "locale"],
      "properties": {
        "response_agent": { "type": "string", "const": "C4_bridge_response_shaper" },
        "expected_result_type": { "type": "string" },
        "context_ref": { "type": "string" },
        "locale": { "type": "string" }
      }
    },
    "next_agent": { "type": "string", "const": "K0_runtime_orchestrator" }
  }
}
