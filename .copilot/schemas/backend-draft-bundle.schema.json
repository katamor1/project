// .copilot/schemas/backend-draft-bundle.schema.json
// Defines the backend draft bundle schema used to describe Python route and service skeleton files.
// This exists so backend code drafts can be reviewed as concrete draft files and contracts before repo handoff.
// RELEVANT FILES: .copilot/prompts/P17_backend_draft_author.md, .copilot/schemas/draft-file.schema.json, docs/sdlc/templates/backend-draft-bundle.md
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "backend-draft-bundle.schema.json",
  "title": "Backend Draft Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_manifest",
    "slice_id",
    "files",
    "route_contracts",
    "service_flow",
    "auth_rules",
    "next_agent"
  ],
  "properties": {
    "artifact_manifest": { "$ref": "./artifact-manifest.schema.json" },
    "slice_id": { "type": "string" },
    "files": { "type": "array", "items": { "$ref": "./draft-file.schema.json" } },
    "route_contracts": { "type": "array", "items": { "type": "string" } },
    "service_flow": { "type": "array", "items": { "type": "string" } },
    "auth_rules": { "type": "array", "items": { "type": "string" } },
    "next_agent": { "type": "string", "const": "P18_sqlite_draft_author" }
  }
}
