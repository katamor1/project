// .copilot/schemas/document-record.schema.json
// Defines the normalized legacy document record schema used at the start of ingestion.
// This exists so file identity, taxonomy, ACL, and approval state stay stable across reindex runs.
// RELEVANT FILES: .copilot/prompts/K1_intake_normalizer.md, .copilot/schemas/acl-principal-set.schema.json, docs/external-runtime/legacy-kb/data-pipeline.md
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "document-record.schema.json",
  "title": "Document Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["doc_id", "version_id", "source_path", "doc_type", "module", "approval_status", "acl", "hash"],
  "properties": {
    "doc_id": { "type": "string" },
    "version_id": { "type": "string" },
    "source_path": { "type": "string" },
    "doc_type": { "type": "string" },
    "module": { "type": "string" },
    "business_domain": { "type": "string" },
    "approval_status": { "type": "string", "enum": ["approved", "draft", "unknown"] },
    "acl": { "$ref": "acl-principal-set.schema.json" },
    "hash": { "type": "string" }
  }
}
