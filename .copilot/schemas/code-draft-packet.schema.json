// .copilot/schemas/code-draft-packet.schema.json
// Defines the code draft packet schema used to start the integration lane from execution bundles.
// This exists so skeleton draft generation can begin with fixed targets, constraints, and repo references.
// RELEVANT FILES: .copilot/prompts/P15_integration_bundle_planner.md, .copilot/schemas/draft-file.schema.json, docs/sdlc/templates/integration-bundle-plan.md
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "code-draft-packet.schema.json",
  "title": "Code Draft Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "slice_id",
    "execution_bundle_ref",
    "target_repo_map_ref",
    "draft_targets",
    "constraints",
    "done_criteria",
    "next_agent"
  ],
  "properties": {
    "request_id": { "type": "string" },
    "slice_id": { "type": "string" },
    "execution_bundle_ref": { "type": "string" },
    "target_repo_map_ref": { "type": "string" },
    "draft_targets": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "done_criteria": { "type": "array", "items": { "type": "string" } },
    "next_agent": { "type": "string", "const": "P16_frontend_draft_author" }
  }
}
