// .copilot/schemas/entry-human-checkpoint.schema.json
// Defines the explicit human checkpoint schema returned when the bridge cannot safely dispatch or continue.
// This exists so blocked requests always tell the user what to fix before retrying.
// RELEVANT FILES: .copilot/prompts/entry/ibmbob-identity-scope-guard.md, .copilot/prompts/entry/ibmbob-entry-response-shaper.md, docs/copilot-studio/custom-engine-bridge/identity-scope.md
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "entry-human-checkpoint.schema.json",
  "title": "Entry Human Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": ["reason", "required_user_action", "blocked_target", "retry_entry"],
  "properties": {
    "reason": { "type": "string" },
    "required_user_action": { "type": "string" },
    "blocked_target": { "type": "string" },
    "retry_entry": { "type": "string" }
  }
}


