// .copilot/schemas/sqlite-change-pack.schema.json
// Defines the SQLite change pack schema used to describe schema intent and migration draft notes.
// This exists so DB responsibility stays explicit and separate from the backend codepack.
// RELEVANT FILES: .copilot/prompts/P12_backend_codepack_author.md, docs/sdlc/templates/sqlite-change-pack.md, .copilot/schemas/backend-codepack.schema.json
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sqlite-change-pack.schema.json",
  "title": "SQLite Change Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_manifest",
    "slice_id",
    "target_files",
    "schema_changes",
    "migration_draft",
    "rollback_notes",
    "next_agent"
  ],
  "properties": {
    "artifact_manifest": { "$ref": "./artifact-manifest.schema.json" },
    "slice_id": { "type": "string" },
    "target_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "purpose", "skeleton_outline"],
        "properties": {
          "path": { "type": "string" },
          "purpose": { "type": "string" },
          "skeleton_outline": { "type": "string" }
        }
      }
    },
    "schema_changes": { "type": "array", "items": { "type": "string" } },
    "migration_draft": { "type": "string" },
    "rollback_notes": { "type": "string" },
    "next_agent": { "type": "string", "const": "P13_test_codepack_author" }
  }
}
