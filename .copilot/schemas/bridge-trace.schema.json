// .copilot/schemas/bridge-trace.schema.json
// Defines the bridge trace schema used to connect Copilot entry routing with runtime and checkpoint behavior.
// This exists so pilot runs can inspect the bridge path without reading raw response bodies.
// RELEVANT FILES: .copilot/prompts/C5_bridge_eval_monitor.md, docs/copilot-studio/custom-engine-bridge/pilot-runbook.md, .copilot/routing/custom-engine-bridge-matrix.yaml
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bridge-trace.schema.json",
  "title": "Bridge Trace",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "copilot_surface", "bridge_path", "runtime_run_ref", "checkpoint_flags", "latency_ms"],
  "properties": {
    "request_id": { "type": "string" },
    "copilot_surface": { "type": "string" },
    "bridge_path": { "type": "array", "items": { "type": "string" } },
    "runtime_run_ref": { "type": "string" },
    "checkpoint_flags": { "type": "array", "items": { "type": "string" } },
    "latency_ms": { "type": "integer", "minimum": 0 }
  }
}
