// .copilot/schemas/entry-response.schema.json
// Defines the Claude Code-facing entry response schema used for answers, abstains, handoffs, and checkpoints.
// This exists so user-facing bridge replies stay short and structurally consistent across runtime outcomes.
// RELEVANT FILES: .copilot/prompts/C4_entry_response_shaper.md, .copilot/schemas/entry-human-checkpoint.schema.json, docs/claude-code/runtime-bridge/response-shaping.md
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "entry-response.schema.json",
  "title": "Entry Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["response_mode", "user_message", "downstream_target", "handoff_state", "human_checkpoint", "citations_policy"],
  "properties": {
    "response_mode": { "type": "string", "enum": ["answer", "abstain", "handoff", "checkpoint"] },
    "user_message": { "type": "string" },
    "downstream_target": { "type": "string" },
    "handoff_state": { "type": "string" },
    "human_checkpoint": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "bridge-human-checkpoint.schema.json" }
      ]
    },
    "citations_policy": { "type": "string" }
  }
}
