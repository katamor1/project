// .copilot/schemas/bridge-identity-context.schema.json
// Defines the Copilot bridge identity context schema used before runtime dispatch.
// This exists so principal, tenant, and allowed scope checks use one stable contract.
// RELEVANT FILES: .copilot/prompts/C2_identity_scope_guard.md, .copilot/schemas/bridge-human-checkpoint.schema.json, docs/copilot-studio/custom-engine-bridge/identity-scope.md
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bridge-identity-context.schema.json",
  "title": "Bridge Identity Context",
  "type": "object",
  "additionalProperties": false,
  "required": ["user_principal", "groups", "tenant", "copilot_surface", "allowed_scopes"],
  "properties": {
    "user_principal": { "type": "string" },
    "groups": { "type": "array", "items": { "type": "string" } },
    "tenant": { "type": "string" },
    "copilot_surface": { "type": "string" },
    "allowed_scopes": { "type": "array", "items": { "type": "string" } }
  }
}
