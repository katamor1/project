// .copilot/schemas/acl-principal-set.schema.json
// Defines the ACL principal set schema attached to documents, chunks, and query contexts.
// This exists so query-time trim and evidence-time recheck use one stable identity contract.
// RELEVANT FILES: .copilot/schemas/document-record.schema.json, docs/external-runtime/legacy-kb/security-acl.md, .copilot/prompts/runtime/ibmbob-evidence-reviewer.md
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "acl-principal-set.schema.json",
  "title": "ACL Principal Set",
  "type": "object",
  "additionalProperties": false,
  "required": ["users", "groups", "tenant"],
  "properties": {
    "users": { "type": "array", "items": { "type": "string" } },
    "groups": { "type": "array", "items": { "type": "string" } },
    "tenant": { "type": "string" },
    "sensitivity_label": { "type": "string" }
  }
}

